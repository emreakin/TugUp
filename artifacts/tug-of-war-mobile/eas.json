{
  "cli": {
    "version": ">= 5.9.0",
    "requireCommit": false,
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "node": "22.14.0",
      "pnpm": "10.15.1",
      "developmentClient": true,
      "distribution": "internal",
      "ios": {
        "simulator": true
      },
      "android": {
        "buildType": "apk"
      },
      "env": {
        "EXPO_PUBLIC_ADMOB_REWARDED_UNIT_ID": "ca-app-pub-5692796466438151/4906976811",
        "EXPO_PUBLIC_API_BASE": "https://tugup-api.onrender.com"
      }
    },
    "preview": {
      "node": "22.14.0",
      "pnpm": "10.15.1",
      "distribution": "internal",
      "android": {
        "buildType": "apk",
        "gradleCommand": ":app:assembleRelease"
      },
      "env": {
        "EXPO_PUBLIC_ADMOB_REWARDED_UNIT_ID": "ca-app-pub-5692796466438151/4906976811",
        "EXPO_PUBLIC_API_BASE": "https://tugup-api.onrender.com"
      }
    },
    "production": {
      "node": "22.14.0",
      "pnpm": "10.15.1",
      "autoIncrement": true,
      "android": {
        "buildType": "apk"
      },
      "env": {
        "EXPO_PUBLIC_ADMOB_REWARDED_UNIT_ID": "ca-app-pub-5692796466438151/4906976811",
        "EXPO_PUBLIC_API_BASE": "https://tugup-api.onrender.com"
      }
    }
  }
}
