{
  "expo": {
    "name": "TugUp",
    "slug": "tug-of-war-mobile",
    "version": "0.1.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "tug-of-war-mobile",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "linking": {
      "scheme": "tug-of-war-mobile",
      "prefixes": ["tug-of-war-mobile://"]
    },
    "splash": {
      "image": "./assets/images/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0f172a"
    },
    "ios": {
      "supportsTablet": false
    },
    "android": {
      "package": "com.tugup.game",
      "versionCode": 7
    },
    "web": {
      "favicon": "./assets/images/icon.png"
    },
    "plugins": [
      [
        "expo-router",
        {
          "origin": "https://replit.com/"
        }
      ],
      "expo-font",
      "expo-web-browser",
      [
        "react-native-google-mobile-ads",
        {
          "androidAppId": "ca-app-pub-5692796466438151~2238627042",
          "iosAppId": "ca-app-pub-3940256099942544~1458002511"
        }
      ],
      [
        "expo-build-properties",
        {
          "android": {
            "kotlinVersion": "2.2.20"
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "eas": {
        "projectId": "148e2caa-5d9f-4407-935c-1073e6a17339"
      }
    }
  }
}
